# ==========================================
# PETHEAL BACKEND ENVIRONMENT CONFIGURATION
# ==========================================
# NGROK SETUP INSTRUCTIONS:
#
# 1. Start Laravel: php artisan serve --port=8000
# 2. Start ngrok: ngrok http 8000
# 3. Copy the ngrok URL (e.g., https://abc123.ngrok-free.app)
# 4. Update APP_URL below with your ngrok URL
# 5. The Android app's BACKEND_BASE_URL must use this SAME URL + /api/
#
# CRITICAL:
# - APP_URL and BACKEND_BASE_URL MUST match
# - Always use HTTPS for ngrok
# - This prevents ALL IP-related errors
# ==========================================

APP_NAME=PetHeal
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# NGROK URL (RECOMMENDED):
APP_URL=https://your-ngrok-url.ngrok-free.app

# Local development (ONLY if NOT using ngrok):
# APP_URL=http://localhost:8000

# ==========================================
# Database Configuration
# ==========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=travelo
DB_USERNAME=root
DB_PASSWORD=

# ==========================================
# Firebase - Push Notifications (FCM V1 API)
# ==========================================
# Download Service Account JSON from:
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# Save it to: storage/app/firebase-service-account.json
# ==========================================
FIREBASE_CREDENTIALS=storage/app/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=storage/app/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ==========================================
# Midtrans - Payment Gateway
# ==========================================
# Get keys from: https://dashboard.midtrans.com/
# Sandbox (testing): Use sandbox keys
# Production: Use production keys and set MIDTRANS_IS_PRODUCTION=true
# ==========================================
MIDTRANS_SERVER_KEY=your-midtrans-server-key-here
MIDTRANS_CLIENT_KEY=your-midtrans-client-key-here
MIDTRANS_IS_PRODUCTION=false

# ==========================================
# FCM - Legacy API Key (NOT USED)
# ==========================================
# This project uses FCM V1 API with Service Account JSON (see above).
# The legacy FCM Server Key is DEPRECATED and NOT required.
# Keep this as placeholder or remove it.
# ==========================================
FCM_API_KEY=your-fcm-api-key-here
FCM_SENDER_ID=your-fcm-sender-id
